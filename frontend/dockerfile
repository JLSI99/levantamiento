# frontend/dockerfile
FROM nginx:1.25.4-alpine

# 1. Eliminar la configuración por defecto de Nginx
RUN rm /etc/nginx/conf.d/default.conf

# 2. Copiar nuestra configuración optimizada con el proxy perimetral hacia el BFF
COPY nginx.conf /etc/nginx/conf.d/

# 3. Copiar los archivos estáticos respetando la jerarquía de directorios
COPY index.html /usr/share/nginx/html/
COPY css/ /usr/share/nginx/html/css/
COPY src/ /usr/share/nginx/html/src/

# Exponer el puerto perimetral web
EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]